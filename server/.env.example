# Copy this file to .env on the server, then fill real values. Never commit .env.
PORT=3000
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret-at-least-48-characters
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=https://your-domain.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Qevora Studio <noreply@your-domain.com>
ALLOW_DEV_CODES=false

SMS_MOCK=false
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=QEVORA
SMS_TEMPLATE_CODE=

USDT_ADDRESS=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USDT_NETWORK=TRC20
USDT_RATE=7.2
